│
├── notebooks/
│   └── 01_eda.ipynb      # Exploratory data analysis
│
├── pipelines/
│   ├── preprocess.py     # Data cleaning pipeline
│   ├── features.py       # Feature engineering pipeline
│   ├── baseline_model.py # Naive baseline for benchmarking
│   ├── train_model.py    # XGBoost training pipeline
│   └── explain_model.py  # SHAP explainability
│
├── models/
│   ├── xgboost_model.pkl # Trained model artifact
│   └── feature_cols.pkl  # Feature list used in training
│
├── api/
│   └── main.py           # FastAPI application
│
├── dashboard/
│   └── app.py            # Streamlit dashboard
│
├── reports/
│   ├── shap_summary.png          # SHAP feature importance plot
│   ├── dashboard_overview.png    # Overview page screenshot
│   ├── dashboard_simulator.png   # Promotion simulator screenshot
